# Copy this file to .env and fill in values

# Model selection
DEFAULT_MODEL=sshleifer/distilbart-cnn-12-6

# Device: auto | cuda | cpu
DEVICE=auto

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Generation defaults (can be overridden per request)
MAX_OUTPUT_LENGTH=256
MIN_OUTPUT_LENGTH=50
NUM_BEAMS=4
